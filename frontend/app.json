{
	"expo": {
		"name": "RoadLift",
		"slug": "RoadLift",
		"scheme": "roadlift",
		"version": "1.0.0",
		"sdkVersion": "54.0.0",
		"platforms": ["ios", "android"],
		"icon": "./assets/icon.png",
		"splash": {
			"image": "./assets/icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff"
		},
		"plugins": [
			[
				"expo-notifications",
				{
					"icon": "./assets/icon.png",
					"color": "#1A6BFF",
					"sounds": []
				}
			]
		],
		"android": {
			"package": "com.aryan1703.RoadLift",
			"permissions": [
				"ACCESS_COARSE_LOCATION",
				"ACCESS_FINE_LOCATION",
				"RECEIVE_BOOT_COMPLETED",
				"VIBRATE",
				"POST_NOTIFICATIONS"
			]
		},
		"ios": {
			"bundleIdentifier": "com.aryan1703.RoadLift",
			"entitlements": {
				"com.apple.developer.in-app-payments": ["merchant.com.aryan1703.RoadLift"]
			},
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false,
				"NSLocationWhenInUseUsageDescription": "We need your location to show the driver where you are and to track your route.",
				"NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to show the driver where you are and to track your route.",
				"UIBackgroundModes": ["remote-notification", "location", "fetch"]
			}
		},
		"extra": {
			"eas": {
				"projectId": "ad2db119-04d3-4517-be8a-4b4de6194806"
			}
		},
		"owner": "aryan1703"
	}
}
